{
  "name": "@tearleads/local-write-orchestrator",
  "version": "0.0.4",
  "description": "Local SQLite write orchestration primitives",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runBunPerFile.sh --root src --coverage"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "cross-env": "10.1.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
