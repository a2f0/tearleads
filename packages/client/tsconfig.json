      "@tearleads/app-calendar/package.json": ["../app-calendar/package.json"],
      "@tearleads/app-calendar": ["../app-calendar/src/index.ts"],
      "@tearleads/app-camera/package.json": ["../app-camera/package.json"],
      "@tearleads/app-camera": ["../app-camera/src/index.ts"],
      "@tearleads/app-classic/package.json": ["../app-classic/package.json"],
      "@tearleads/app-classic": ["../app-classic/src/index.ts"],
      "@tearleads/app-compliance/package.json": ["../app-compliance/package.json"],
      "@tearleads/app-compliance": ["../app-compliance/src/index.ts"],
