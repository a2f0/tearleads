{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsc/tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@client/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@docs/*": ["../../docs/*"],
      "@admin/*": ["../app-admin/src/*"],
      "@tearleads/app-admin/package.json": ["../app-admin/package.json"],
      "@tearleads/app-admin": ["../app-admin/src/index.ts"],
      "@tearleads/app-admin/clientEntry": ["../app-admin/src/clientEntry.ts"],
