      "@tearleads/app-terminal/package.json": ["../app-terminal/package.json"],
      "@tearleads/app-terminal": ["../app-terminal/src/index.ts"],
      "@tearleads/ui/package.json": ["../ui/package.json"],
      "@tearleads/ui": ["../ui/src/index.ts"],
      "@tearleads/app-vehicles/package.json": ["../app-vehicles/package.json"],
      "@tearleads/app-vehicles": ["../app-vehicles/src/index.ts"],
      "@tearleads/vfs-explorer/package.json": ["../vfs-explorer/package.json"],
      "@tearleads/vfs-explorer": ["../vfs-explorer/src/index.ts"],
      "@tearleads/mls-core/package.json": ["../mls-core/package.json"],
      "@tearleads/mls-core": ["../mls-core/src/index.ts"],
      "@tearleads/app-mls-chat/package.json": ["../app-mls-chat/package.json"],
