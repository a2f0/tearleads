{
  "name": "@tearleads/app-builder",
  "version": "1.0.20",
  "private": true,
  "description": "White-label app builder for multi-app builds",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./vite": {
      "import": "./src/vite/createAppConfigPlugin.ts",
      "types": "./src/vite/createAppConfigPlugin.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    }
  },
  "bin": {
    "app-builder": "./src/cli.ts"
  },
  "scripts": {
    "generate": "tsx src/cli.ts generate",
    "validate": "tsx src/cli.ts validate",
    "list": "tsx src/cli.ts list",
    "test": "bun test src/generators/theme.test.ts src/generators/utils.test.ts",
    "testVitest": "sh ../../scripts/tooling/pm.sh -w exec vitest run packages/app-builder/src/generators/theme.test.ts packages/app-builder/src/generators/utils.test.ts",
    "test:coverage": "sh ./scripts/testCoverage.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tearleads/shared": "workspace:*",
    "commander": "14.0.3",
    "jiti": "2.6.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
