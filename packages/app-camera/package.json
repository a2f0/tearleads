{
  "name": "@tearleads/app-camera",
  "version": "0.0.12",
  "description": "Camera capture components for Tearleads",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true bun test --preload ./src/test/bunSetup.ts src/**/*.test.ts src/**/*.test.tsx",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true BUN_TEST_PRELOAD=./src/test/bunSetup.ts BUN_TEST_PATTERNS=./src/**/*.test.ts,./src/**/*.test.tsx sh ../../scripts/test/runCoverage.sh"
  },
  "peerDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "dependencies": {
    "lucide-react": "0.576.0"
  },
  "devDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jsdom": "28.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "10.1.0",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
