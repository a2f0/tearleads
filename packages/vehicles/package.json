{
  "name": "@tearleads/vehicles",
  "version": "0.0.10",
  "description": "Vehicle profile utilities for Tearleads",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vehiclesDb": {
      "types": "./src/lib/vehiclesDb.ts",
      "import": "./src/lib/vehiclesDb.ts"
    },
    "./vehiclesState": {
      "types": "./src/lib/vehiclesState.ts",
      "import": "./src/lib/vehiclesState.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@tearleads/db": "workspace:*",
    "@tearleads/shared": "workspace:*",
    "react": "19.2.4"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "testVitest": "cross-env DOTENV_CONFIG_QUIET=true vitest run",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; if command -v bun >/dev/null 2>&1; then bun test --coverage --concurrency=\"${PRE_PUSH_MAX_WORKERS:-${PRE_PUSH_VITEST_MAX_WORKERS:-4}}\" \"$@\"; else vitest run --coverage --max-workers=\"${PRE_PUSH_MAX_WORKERS:-${PRE_PUSH_VITEST_MAX_WORKERS:-4}}\" \"$@\"; fi' --"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "4.0.18",
    "react": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1"
  }
}
