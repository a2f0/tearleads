{
  "name": "@tearleads/bun-dom-compat",
  "version": "0.0.6",
  "description": "Shared JSDOM browser-globals installer for Bun test environments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bun",
    "jsdom",
    "test",
    "compat"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "jsdom": "28.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "27.0.0",
    "@types/node": "25.3.3",
    "typescript": "5.9.3"
  }
}
