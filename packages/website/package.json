{
  "name": "@tearleads/website",
  "version": "0.0.284",
  "description": "Marketing website for Tearleads",
  "type": "module",
  "scripts": {
    "dev": "tsx ../../scripts/lib/killPnpmDev.ts && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true bun test --preload ./src/test/bunSetup.ts src/**/*.test.ts src/**/*.test.tsx",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runBunPerFile.sh --preload ./src/test/bunSetup.ts --root src --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tearleads/shared": "workspace:*",
    "@tearleads/ui": "workspace:*",
    "astro": "5.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@astrojs/react": "4.4.2",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "28.1.0",
    "lucide-react": "0.576.0",
    "tailwindcss": "4.2.1",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
