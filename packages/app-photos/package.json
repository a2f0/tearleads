{
  "name": "@tearleads/app-photos",
  "version": "0.0.17",
  "description": "Photo management components for Tearleads",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runBunPerFile.sh --root src --coverage"
  },
  "peerDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "dependencies": {
    "@tanstack/react-virtual": "3.13.21",
    "lucide-react": "0.576.0"
  },
  "devDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
