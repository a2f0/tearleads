{
  "name": "@tearleads/app-classic",
  "version": "0.0.63",
  "description": "Classic tag-and-note workspace for Tearleads",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist dist-tests coverage",
    "test": "cross-env DOTENV_CONFIG_QUIET=true bun test --preload ./src/test/bunSetup.ts ./src/**/*.test.ts ./src/**/*.test.tsx",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true BUN_TEST_PRELOAD=./src/test/bunSetup.ts BUN_TEST_PATTERNS=./src/**/*.test.ts,./src/**/*.test.tsx bash ../../scripts/test/runCoverage.sh || cross-env DOTENV_CONFIG_QUIET=true vitest run --coverage"
  },
  "peerDependencies": {
    "@tearleads/window-manager": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6"
  },
  "devDependencies": {
    "@tearleads/window-manager": "workspace:*",
    "@tearleads/db": "workspace:*",
    "@tearleads/db-test-utils": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-orm": "0.45.1",
    "i18next": "25.8.14",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "@types/jsdom": "28.0.0",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
