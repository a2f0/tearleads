{
  "name": "@tearleads/app-vehicles",
  "version": "0.0.15",
  "description": "Vehicle profile utilities for Tearleads",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vehiclesDb": {
      "types": "./src/lib/vehiclesDb.ts",
      "import": "./src/lib/vehiclesDb.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@tearleads/db": "workspace:*",
    "@tearleads/shared": "workspace:*",
    "drizzle-orm": "0.45.1",
    "react": "19.2.4"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runCoverage.sh"
  },
  "devDependencies": {
    "@tearleads/db": "workspace:*",
    "@tearleads/shared": "workspace:*",
    "@types/react": "19.2.14",
    "drizzle-orm": "0.45.1",
    "react": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1"
  }
}
