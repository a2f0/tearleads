{
  "name": "@tearleads/app-analytics",
  "version": "0.0.31",
  "description": "Analytics window for Tearleads",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./clientEntry": {
      "types": "./src/clientEntry.ts",
      "import": "./src/clientEntry.ts"
    },
    "./analytics": {
      "types": "./src/lib/analytics.ts",
      "import": "./src/lib/analytics.ts"
    },
    "./analyticsState": {
      "types": "./src/lib/analyticsState.ts",
      "import": "./src/lib/analyticsState.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "echo \"@tearleads/app-analytics is source-consumed via Vite aliases\"",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true bun test --preload ./src/test/bunSetup.ts ./src/**/*.test.ts ./src/**/*.test.tsx",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true BUN_TEST_PRELOAD=./src/test/bunSetup.ts BUN_TEST_PATTERNS=./src/**/*.test.ts,./src/**/*.test.tsx bash ../../scripts/test/runCoverage.sh || cross-env DOTENV_CONFIG_QUIET=true vitest run --coverage",
    "testVitest": "cross-env DOTENV_CONFIG_QUIET=true vitest run"
  },
  "peerDependencies": {
    "@tearleads/db": "workspace:*",
    "@tearleads/shared": "workspace:*",
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "dependencies": {
    "@tanstack/react-virtual": "3.13.19",
    "lucide-react": "0.576.0",
    "recharts": "3.7.0"
  },
  "devDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "cross-env": "10.1.0",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "@types/jsdom": "27.0.0",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
