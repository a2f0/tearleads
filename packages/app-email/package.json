{
  "name": "@tearleads/app-email",
  "version": "0.0.120",
  "description": "Email components for Tearleads",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runWithTimeout.sh --seconds 75 bun test --preload ./src/test/bunSetup.ts ./src/**/*.test.ts ./src/**/*.test.tsx",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true BUN_TEST_PRELOAD=./src/test/bunSetup.ts BUN_TEST_PATTERNS=./src/**/*.test.ts,./src/**/*.test.tsx bash ../../scripts/test/runCoverage.sh || cross-env DOTENV_CONFIG_QUIET=true vitest run --coverage"
  },
  "peerDependencies": {
    "@tearleads/db": "workspace:*",
    "@tearleads/shared": "workspace:*",
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "drizzle-orm": "0.45.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "dompurify": "3.3.2",
    "drizzle-orm": "0.45.1",
    "lucide-react": "0.576.0",
    "postal-mime": "2.7.3"
  },
  "devDependencies": {
    "@tearleads/db": "workspace:*",
    "@tearleads/db-test-utils": "workspace:*",
    "@tearleads/shared": "workspace:*",
    "@tearleads/ui": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "@types/jsdom": "28.0.0",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
