{
  "name": "@tearleads/app-notifications",
  "version": "0.0.26",
  "description": "Notification Center window for Tearleads",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./clientEntry": {
      "types": "./src/clientEntry.ts",
      "import": "./src/clientEntry.ts"
    },
    "./stores": {
      "types": "./src/stores/index.ts",
      "import": "./src/stores/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "echo \"@tearleads/app-notifications is source-consumed via Vite aliases\"",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true bun test --preload ./src/test/bunSetup.ts ./src/**/*.test.ts ./src/**/*.test.tsx",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true BUN_TEST_PRELOAD=./src/test/bunSetup.ts BUN_TEST_PATTERNS=./src/**/*.test.ts,./src/**/*.test.tsx bash ../../scripts/test/runCoverage.sh || cross-env DOTENV_CONFIG_QUIET=true vitest run --coverage"
  },
  "peerDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6"
  },
  "dependencies": {
    "lucide-react": "0.576.0"
  },
  "devDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "10.1.0",
    "i18next": "25.8.14",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "@types/jsdom": "28.0.0",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
