{
  "name": "@tearleads/app-help",
  "version": "0.0.27",
  "description": "Help pages and window for Tearleads",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "echo \"@tearleads/app-help is source-consumed via Vite aliases\"",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runBunPerFile.sh --preload ./src/test/bunSetup.ts",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true sh ../../scripts/test/runBunPerFile.sh --preload ./src/test/bunSetup.ts --root src --coverage"
  },
  "peerDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6",
    "react-router-dom": "7.13.1"
  },
  "dependencies": {
    "@tearleads/app-backups": "workspace:*",
    "lucide-react": "0.576.0"
  },
  "devDependencies": {
    "@tearleads/ui": "workspace:*",
    "@tearleads/window-manager": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "10.1.0",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6",
    "react-router-dom": "7.13.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "@types/jsdom": "28.0.0",
    "@tearleads/bun-dom-compat": "workspace:*"
  }
}
