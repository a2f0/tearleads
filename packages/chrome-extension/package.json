{
  "name": "@tearleads/chrome-extension",
  "version": "0.0.168",
  "description": "Chrome extension for Tearleads",
  "type": "module",
  "scripts": {
    "dev": "cross-env DOTENV_CONFIG_QUIET=true vite build --watch",
    "build": "tsc && cross-env DOTENV_CONFIG_QUIET=true vite build",
    "clean": "rm -rf dist",
    "test": "cross-env DOTENV_CONFIG_QUIET=true bun test --preload ./src/test/bunSetup.ts ./src/**/*.test.ts ./src/**/*.test.tsx",
    "test:watch": "cross-env DOTENV_CONFIG_QUIET=true vitest",
    "test:coverage": "cross-env DOTENV_CONFIG_QUIET=true BUN_TEST_PRELOAD=./src/test/bunSetup.ts BUN_TEST_PATTERNS=./src/**/*.test.ts sh ../../scripts/test/runCoverage.sh"
  },
  "devDependencies": {
    "@tearleads/bun-dom-compat": "workspace:*",
    "@types/chrome": "0.1.37",
    "@types/node": "25.3.5",
    "cross-env": "10.1.0",
    "jsdom": "28.1.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1"
  }
}
